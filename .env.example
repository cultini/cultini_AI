# CULTINI backend configuration — copy to .env and fill in.
#   cp .env.example .env
# Only GEMINI_API_KEY is required; everything else has a sensible default
# (the values below mirror app/config.py).

# --- Gemini (REQUIRED) ---
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY is accepted as an alias if you prefer the google-genai default.
GEMINI_API_KEY=

# --- Models (optional) ---
# NOTE: gemini-2.0-flash's free tier can be 0 req/day on some keys → 429.
# gemini-2.5-flash is a safe default with free-tier quota.
AZETTA_LLM_MODEL=gemini-2.5-flash
AZETTA_EMBED_MODEL=gemini-embedding-001

# --- Agentic router / chat (optional) ---
# Retrieval-score gate: below this, answer with the bare LLM (route='direct').
AZETTA_ROUTER_THRESHOLD=0.6
# Turns (user + assistant) kept in a chat's context window (~3 exchanges).
AZETTA_CHAT_HISTORY_TURNS=6

# --- Contributions / auto-moderation (optional) ---
# Cosine similarity at/above which a submission is treated as a duplicate.
# (~0.92 = verbatim re-submission, ~0.73 = different fiche same topic.)
AZETTA_DUPLICATE_THRESHOLD=0.85
# Body shorter than this many characters is treated as spam.
AZETTA_SPAM_MIN_CONTENT_LEN=30
# More links than this in title+body flags spam.
AZETTA_SPAM_MAX_LINK_COUNT=2

# --- CORS (optional) ---
# Comma-separated explicit origins (production). Local dev frontends (Flutter web
# on a random localhost port) are covered by the regex below.
AZETTA_CORS_ORIGINS=http://localhost:3000
# AZETTA_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
